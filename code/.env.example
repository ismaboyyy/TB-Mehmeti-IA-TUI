# =====================================================================
# Configuration globale du projet (copier ce fichier en .env)
#   cp .env.example .env
# =====================================================================

# ---------- PostgreSQL ----------
POSTGRES_USER=tui
POSTGRES_PASSWORD=tui_password
POSTGRES_DB=tui_assistant
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ---------- Qdrant ----------
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=tui_chunks

# ---------- Ollama ----------
# En local hors Docker : http://localhost:11434
OLLAMA_BASE_URL=http://ollama:11434
# Modèle de génération par défaut (testés : llama3.2:3b, qwen2.5:7b, mistral:7b)
OLLAMA_LLM_MODEL=qwen2.5:7b
# Modèles par agent (optionnels). Laisser vide = utiliser OLLAMA_LLM_MODEL pour tout.
# Permet ex. un petit modèle pour la reformulation et un plus gros pour la synthèse.
OLLAMA_UNDERSTAND_MODEL=
OLLAMA_SYNTHESIZE_MODEL=
# Listes de modèles proposées PAR AGENT dans l'UI (séparées par des virgules).
# Vide = liste commune (OLLAMA_MODELS) pour les deux sélecteurs.
OLLAMA_UNDERSTAND_MODELS=
OLLAMA_SYNTHESIZE_MODELS=

# ---------- Embeddings ----------
# BGE-M3 chargé localement via sentence-transformers / FlagEmbedding
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024

# ---------- RAG ----------
CHUNK_SIZE=900
CHUNK_OVERLAP=150
RETRIEVAL_TOP_K=6
# Sources regroupées par article : pool de chunks récupérés dans Qdrant, nombre
# max d'articles affichés/cités, et nombre max de pages gardées par article.
RETRIEVAL_POOL=24
SOURCES_MAX_ARTICLES=8
SOURCES_MAX_PASSAGES=2
# Stratégie de découpage à l'ingestion (affecte uniquement l'indexation) :
#   blocks = blocs PyMuPDF triés en ordre de lecture (corrige titre/colonnes, défaut)
#   char   = texte aplati découpé par caractères
CHUNK_STRATEGY=blocks
# Exclut les sections bibliographiques de l'index (stratégie "blocks" uniquement).
EXCLUDE_REFERENCES=true

# ---------- Backend ----------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
# Origines autorisées pour le CORS (frontend)
CORS_ORIGINS=http://localhost:3000

# ---------- Authentification (JWT) ----------
# Secret de signature des jetons. À CHANGER (valeur longue et aléatoire).
JWT_SECRET=dev-secret-change-me
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ---------- Frontend ----------
# URL du backend vue depuis le navigateur
NEXT_PUBLIC_API_URL=http://localhost:8000

# ---------- Tracing (Langfuse) ----------
# Clés provisionnées automatiquement par le conteneur Langfuse (cf. docker-compose).
# Vider ces deux clés pour désactiver complètement le tracing.
LANGFUSE_PUBLIC_KEY=pk-lf-tui-local
LANGFUSE_SECRET_KEY=sk-lf-tui-local-secret
# URL vue par le backend (réseau Docker). Interface web : http://localhost:3001
LANGFUSE_HOST=http://langfuse:3000
