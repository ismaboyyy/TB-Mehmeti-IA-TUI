# =====================================================================
# Modèle d'environnement de DÉPLOIEMENT (devweb.estia.fr/tui_assistant).
# Sur le serveur :  cp .env.prod.example .env  puis remplacer les CHANGE_ME.
# Seuls les 2 secrets ci-dessous sont à modifier ; le reste est déjà bon.
# =====================================================================

# ---------- PostgreSQL ----------
POSTGRES_USER=tui
POSTGRES_PASSWORD=CHANGE_ME_mot_de_passe_fort     # <-- À MODIFIER
POSTGRES_DB=tui_assistant
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ---------- Qdrant ----------
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=tui_chunks

# ---------- Ollama ----------
OLLAMA_BASE_URL=http://ollama:11434
# Modèle par défaut (qwen2.5:7b = qualité ; llama3.2:3b = rapide en CPU)
OLLAMA_LLM_MODEL=qwen2.5:7b
# Modèles proposés dans le sélecteur de l'interface (liste commune, compat)
OLLAMA_MODELS=qwen2.5:7b,mistral:7b,qwen2.5:14b
# Listes PAR AGENT (prioritaires sur OLLAMA_MODELS pour chaque sélecteur) :
#   reformulation (agent 1) = 7b + mistral ; synthèse (agent 3) = uniquement le 14b.
# Le 1er de chaque liste est la présélection à l'ouverture.
OLLAMA_UNDERSTAND_MODELS=qwen2.5:7b,mistral:7b
OLLAMA_SYNTHESIZE_MODELS=qwen2.5:14b

# ---------- Embeddings ----------
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024

# ---------- RAG ----------
CHUNK_SIZE=900
CHUNK_OVERLAP=150
RETRIEVAL_TOP_K=6
# Sources regroupées par article : pool de chunks, nb max d'articles, nb max de pages/article
RETRIEVAL_POOL=24
SOURCES_MAX_ARTICLES=8
SOURCES_MAX_PASSAGES=2
# Découpage : blocks = blocs PyMuPDF triés en ordre de lecture (2 colonnes) +
# extraction des métadonnées (titre/auteurs/année/DOI). Stratégie de production.
CHUNK_STRATEGY=blocks
# Exclut les sections bibliographiques de l'index (nécessite la stratégie blocks).
EXCLUDE_REFERENCES=true

# ---------- Backend ----------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
# Sous-chemin public de l'API (proxy Apache). Fait pointer Swagger (/docs) vers
# le bon /openapi.json à travers le proxy. Laisser VIDE en local.
ROOT_PATH=/tui_assistant/api
# Front et back partagent le même domaine (Apache) : origine = l'URL publique.
CORS_ORIGINS=https://devweb.estia.fr

# ---------- Authentification (JWT) ----------
JWT_SECRET=CHANGE_ME_secret_long_et_aleatoire     # <-- À MODIFIER (ex: openssl rand -hex 32)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ---------- Frontend ----------
# URL de l'API vue par le navigateur. Derrière Apache, l'API est sous
# /tui_assistant/api. ATTENTION : figé au moment du build du front.
NEXT_PUBLIC_API_URL=https://devweb.estia.fr/tui_assistant/api

# ---------- Tracing (Langfuse) — désactivé en déploiement simple ----------
# Laisser ces clés VIDES : le pipeline tourne normalement, sans observabilité.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=
